{
  "name": "okbrain",
  "version": "0.0.0",
  "description": "Self-hosted, OKF-native personal knowledge manager (TypeScript on Bun).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "okb": "src/cli.ts"
  },
  "scripts": {
    "okb": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile --outfile bin/okb src/cli.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
